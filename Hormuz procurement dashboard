<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Strait of Hormuz — Procurement Risk Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f4f5f7;
  --bg2:#ffffff;
  --bg3:#f0f1f4;
  --bg4:#e4e6ec;
  --border:#dde0e8;
  --border2:#c8ccd8;
  --text:#1a1d2e;
  --text2:#4a4f6a;
  --text3:#8b90a8;
  --red:#d63030;
  --orange:#d96b1a;
  --amber:#b88a00;
  --green:#1a8f5a;
  --teal:#1a8f96;
  --blue:#1a6bbf;
  --purple:#6b4fd4;
  --red-bg:#fdeaea;
  --orange-bg:#fdf0e6;
  --amber-bg:#fdf7e0;
  --green-bg:#e6f7ef;
  --teal-bg:#e6f5f7;
}
body{background:var(--bg);color:var(--text);font-family:'IBM Plex Sans',sans-serif;font-size:14px;line-height:1.5;min-height:100vh}
a{color:var(--blue);text-decoration:none}

/* HEADER */
.header{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 24px}
.header-inner{max-width:1280px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:56px}
.logo{display:flex;align-items:center;gap:10px}
.logo-dot{width:10px;height:10px;background:var(--red);border-radius:50%;animation:pulse 1.8s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(255,76,76,.4)}50%{opacity:.8;box-shadow:0 0 0 6px rgba(255,76,76,0)}}
.logo-text{font-family:'IBM Plex Mono',monospace;font-size:13px;color:var(--text2);letter-spacing:.06em}
.header-badges{display:flex;gap:8px}
.badge{font-family:'IBM Plex Mono',monospace;font-size:10px;padding:3px 8px;border-radius:3px;letter-spacing:.06em;font-weight:600}
.badge-red{background:var(--red-bg);color:var(--red);border:1px solid rgba(214,48,48,.3)}
.badge-amber{background:var(--amber-bg);color:var(--amber);border:1px solid rgba(184,138,0,.3)}
.header-date{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3)}

/* CRISIS BANNER */
.crisis-banner{background:linear-gradient(90deg,rgba(214,48,48,.06) 0%,rgba(217,107,26,.04) 50%,rgba(214,48,48,.06) 100%);border-bottom:1px solid rgba(214,48,48,.18);padding:10px 24px}
.crisis-banner-inner{max-width:1280px;margin:0 auto;display:flex;gap:32px;align-items:center;flex-wrap:wrap}
.stat-pill{display:flex;flex-direction:column;align-items:center;gap:2px}
.stat-pill-label{font-size:10px;color:var(--text3);font-family:'IBM Plex Mono',monospace;letter-spacing:.06em;text-transform:uppercase}
.stat-pill-value{font-family:'IBM Plex Mono',monospace;font-size:16px;font-weight:600}
.stat-pill-value.up{color:var(--red)}
.stat-pill-value.warn{color:var(--amber)}
.stat-pill-value.ok{color:var(--green)}
.divider-v{width:1px;height:36px;background:var(--border2)}

/* TABS */
.tabs-bar{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 24px;position:sticky;top:0;z-index:10}
.tabs-inner{max-width:1280px;margin:0 auto;display:flex;gap:0}
.tab-btn{background:none;border:none;color:var(--text3);font-family:'IBM Plex Sans',sans-serif;font-size:13px;padding:14px 20px;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;letter-spacing:.02em}
.tab-btn:hover{color:var(--text)}
.tab-btn.active{color:var(--amber);border-bottom-color:var(--amber)}

/* MAIN */
.main{max-width:1280px;margin:0 auto;padding:24px}
.tab-panel{display:none}
.tab-panel.active{display:block}

/* SECTION TITLE */
.section-title{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.section-subtitle{font-size:12px;color:var(--text2);margin-top:-10px;margin-bottom:16px}

/* GRID */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
@media(max-width:900px){.grid-2{grid-template-columns:1fr}.grid-3{grid-template-columns:1fr 1fr}.grid-4{grid-template-columns:1fr 1fr}}

/* CARD */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:20px}
.card-sm{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:14px}
.card-title{font-size:12px;color:var(--text2);margin-bottom:4px;font-family:'IBM Plex Mono',monospace;letter-spacing:.04em}
.card-value{font-family:'IBM Plex Mono',monospace;font-size:26px;font-weight:600;margin-bottom:2px}
.card-sub{font-size:11px;color:var(--text3)}

/* CHART WRAPPER */
.chart-wrap{position:relative;width:100%}

/* RISK MATRIX */
.risk-card{background:var(--bg3);border-radius:8px;padding:16px;border-left:3px solid var(--border)}
.risk-card.critical{border-left-color:var(--red);background:rgba(214,48,48,.04)}
.risk-card.high{border-left-color:var(--orange);background:rgba(217,107,26,.04)}
.risk-card.moderate{border-left-color:var(--amber);background:rgba(184,138,0,.04)}
.risk-card.low{border-left-color:var(--green);background:rgba(26,143,90,.04)}
.risk-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
.risk-name{font-size:14px;font-weight:500}
.risk-badge{font-size:10px;font-family:'IBM Plex Mono',monospace;font-weight:600;padding:2px 8px;border-radius:3px;letter-spacing:.06em}
.rb-critical{background:var(--red-bg);color:var(--red);border:1px solid rgba(214,48,48,.3)}
.rb-high{background:var(--orange-bg);color:var(--orange);border:1px solid rgba(217,107,26,.3)}
.rb-moderate{background:var(--amber-bg);color:var(--amber);border:1px solid rgba(184,138,0,.3)}
.rb-low{background:var(--green-bg);color:var(--green);border:1px solid rgba(26,143,90,.3)}
.risk-impact{font-size:13px;font-weight:600;font-family:'IBM Plex Mono',monospace;margin-bottom:6px}
.risk-impact.up{color:var(--red)}
.risk-impact.warn{color:var(--orange)}
.risk-impact.amber{color:var(--amber)}
.risk-items{list-style:none;padding:0}
.risk-items li{font-size:12px;color:var(--text2);padding:2px 0;display:flex;gap:6px}
.risk-items li::before{content:'›';color:var(--text3)}

/* SCENARIO */
.scenario-controls{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:20px}
.scenario-btn{background:var(--bg3);border:1px solid var(--border2);color:var(--text2);font-family:'IBM Plex Mono',monospace;font-size:12px;padding:8px 16px;border-radius:4px;cursor:pointer;transition:all .2s;letter-spacing:.04em}
.scenario-btn.active,.scenario-btn:hover{background:var(--amber-bg);border-color:var(--amber);color:var(--amber)}

/* IMPACT TABLE */
.impact-table{width:100%;border-collapse:collapse;font-size:13px}
.impact-table th{background:var(--bg3);color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:10px 14px;text-align:left;border-bottom:1px solid var(--border)}
.impact-table td{padding:10px 14px;border-bottom:1px solid var(--border);color:var(--text)}
.impact-table tr:hover td{background:rgba(255,255,255,.02)}
.impact-table td.mono{font-family:'IBM Plex Mono',monospace}
.up-text{color:var(--red)}
.warn-text{color:var(--orange)}
.amber-text{color:var(--amber)}
.green-text{color:var(--green)}

/* LOGISTICS */
.timeline-item{display:flex;gap:16px;padding:14px 0;border-bottom:1px solid var(--border)}
.timeline-dot{width:10px;height:10px;min-width:10px;border-radius:50%;margin-top:4px}
.timeline-dot.critical{background:var(--red)}
.timeline-dot.high{background:var(--orange)}
.timeline-dot.moderate{background:var(--amber)}
.timeline-title{font-size:13px;font-weight:500;margin-bottom:4px}
.timeline-body{font-size:12px;color:var(--text2);line-height:1.6}

/* PROGRESS BAR */
.progress-wrap{margin:8px 0}
.progress-label{display:flex;justify-content:space-between;font-size:11px;color:var(--text3);margin-bottom:4px}
.progress-bar{height:6px;background:var(--bg4);border-radius:3px;overflow:hidden}
.progress-fill{height:100%;border-radius:3px;transition:width .6s ease}

/* DATA SOURCE */
.data-sources{margin-top:24px;padding:14px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;font-size:11px;color:var(--text3)}
.data-sources strong{color:var(--text2)}

/* FOOTER */
.footer{max-width:1280px;margin:32px auto 0;padding:0 24px 32px;border-top:1px solid var(--border);padding-top:16px;display:flex;justify-content:space-between;align-items:center;font-size:11px;color:var(--text3)}
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-inner">
    <div class="logo">
      <div class="logo-dot"></div>
      <span class="logo-text">HORMUZ CRISIS · PROCUREMENT INTELLIGENCE</span>
    </div>
    <div class="header-badges">
      <span class="badge badge-red">LIVE CRISIS</span>
      <span class="badge badge-amber">PROCUREMENT ALERT</span>
    </div>
    <div class="header-date">UPDATED: 23 MAR 2026</div>
  </div>
</div>

<!-- CRISIS KPI BANNER -->
<div class="crisis-banner">
  <div class="crisis-banner-inner">
    <div class="stat-pill">
      <span class="stat-pill-label">Oil Disrupted</span>
      <span class="stat-pill-value up">~20%</span>
    </div>
    <div class="divider-v"></div>
    <div class="stat-pill">
      <span class="stat-pill-label">Ships Stranded</span>
      <span class="stat-pill-value up">150+</span>
    </div>
    <div class="divider-v"></div>
    <div class="stat-pill">
      <span class="stat-pill-label">Brent Peak</span>
      <span class="stat-pill-value up">$126/bbl</span>
    </div>
    <div class="divider-v"></div>
    <div class="stat-pill">
      <span class="stat-pill-label">Tanker Traffic</span>
      <span class="stat-pill-value up">↓ 70%</span>
    </div>
    <div class="divider-v"></div>
    <div class="stat-pill">
      <span class="stat-pill-label">Global GDP Impact</span>
      <span class="stat-pill-value up">−2.9pp</span>
    </div>
    <div class="divider-v"></div>
    <div class="stat-pill">
      <span class="stat-pill-label">Closure Duration</span>
      <span class="stat-pill-value warn">23 Days</span>
    </div>
    <div class="divider-v"></div>
    <div class="stat-pill">
      <span class="stat-pill-label">Reroute Add. Days</span>
      <span class="stat-pill-value warn">+14–21d</span>
    </div>
    <div class="divider-v"></div>
    <div class="stat-pill">
      <span class="stat-pill-label">Crisis Start</span>
      <span class="stat-pill-value" style="color:var(--text2);font-size:12px">28 Feb 2026</span>
    </div>
  </div>
</div>

<!-- TABS -->
<div class="tabs-bar">
  <div class="tabs-inner">
    <button class="tab-btn active" onclick="showTab('price')">📈 Commodity Price Impact</button>
    <button class="tab-btn" onclick="showTab('scenario')">🎯 Scenario Planner</button>
    <button class="tab-btn" onclick="showTab('risk')">⚠️ Procurement Risk Matrix</button>
    <button class="tab-btn" onclick="showTab('logistics')">🚢 Logistics & Lead Times</button>
  </div>
</div>

<!-- MAIN CONTENT -->
<div class="main">

  <!-- TAB 1: PRICE IMPACT -->
  <div class="tab-panel active" id="tab-price">
    <div class="section-title">Commodity price movement — Jan → Mar 2026 (source: Sunsirs China, LME)</div>
    <p class="section-subtitle">Based on your uploaded price data. All values in USD-equivalent per tonne unless noted.</p>

    <div class="grid-4" style="margin-bottom:24px">
      <div class="card-sm">
        <div class="card-title">Brent Crude Oil</div>
        <div class="card-value up-text">+47.1%</div>
        <div class="card-sub">Jan: ~$91.5 → Mar: ~$134.6 (indexed)</div>
      </div>
      <div class="card-sm">
        <div class="card-title">Acrylic Acid</div>
        <div class="card-value up-text">+85.1%</div>
        <div class="card-sub">Largest spike in dataset</div>
      </div>
      <div class="card-sm">
        <div class="card-title">Butadiene</div>
        <div class="card-value up-text">+49.3%</div>
        <div class="card-sub">Critical for synthetic rubber</div>
      </div>
      <div class="card-sm">
        <div class="card-title">Benzene</div>
        <div class="card-value up-text">+46.5%</div>
        <div class="card-sub">Key petrochemical feedstock</div>
      </div>
    </div>

    <div class="grid-2" style="margin-bottom:24px">
      <div class="card">
        <div class="card-title" style="margin-bottom:12px">Petrochemical & Energy — % Change Jan→Mar 2026</div>
        <div class="chart-wrap" style="height:340px">
          <canvas id="petroChart"></canvas>
        </div>
      </div>
      <div class="card">
        <div class="card-title" style="margin-bottom:12px">Plastics, Polymers & Feedstocks — % Change Jan→Mar 2026</div>
        <div class="chart-wrap" style="height:340px">
          <canvas id="plasticsChart"></canvas>
        </div>
      </div>
    </div>

    <div class="grid-2" style="margin-bottom:24px">
      <div class="card">
        <div class="card-title" style="margin-bottom:12px">LME Metals — % Change Jan→Mar 2026</div>
        <div class="chart-wrap" style="height:220px">
          <canvas id="metalsChart"></canvas>
        </div>
        <p style="font-size:11px;color:var(--text3);margin-top:8px">Note: Base metals showing relative stability vs petrochemicals — supply chains via different routes</p>
      </div>
      <div class="card">
        <div class="card-title" style="margin-bottom:12px">Agricultural & Other Commodities — % Change Jan→Mar 2026</div>
        <div class="chart-wrap" style="height:220px">
          <canvas id="agriChart"></canvas>
        </div>
      </div>
    </div>


  </div>

  <!-- TAB 2: SCENARIO PLANNER -->
  <div class="tab-panel" id="tab-scenario">
    <div class="section-title">Dallas Fed Scenario Analysis — Strait of Hormuz Closure Duration</div>
    <p class="section-subtitle">Source: Federal Reserve Bank of Dallas (March 20, 2026). Modelled impact on oil prices, global GDP & US economy.</p>

    <div class="scenario-controls">
      <button class="scenario-btn active" onclick="selectScenario(0,this)">Scenario 1: 1-Quarter Closure (Resolves Q3)</button>
      <button class="scenario-btn" onclick="selectScenario(1,this)">Scenario 2: 2-Quarter Closure (Resolves Q4)</button>
      <button class="scenario-btn" onclick="selectScenario(2,this)">Scenario 3: 3-Quarter Closure (Year-End)</button>
    </div>

    <div class="grid-4" style="margin-bottom:20px" id="scenario-kpis">
      <!-- Filled by JS -->
    </div>

    <div class="grid-2" style="margin-bottom:24px">
      <div class="card">
        <div class="card-title" style="margin-bottom:12px">Oil Price Trajectory (WTI $/bbl) — 2026 by Quarter</div>
        <div class="chart-wrap" style="height:280px">
          <canvas id="oilScenarioChart"></canvas>
        </div>
      </div>
      <div class="card">
        <div class="card-title" style="margin-bottom:12px">Global GDP Growth Impact — Annualized %, 2026</div>
        <div class="chart-wrap" style="height:280px">
          <canvas id="gdpChart"></canvas>
        </div>
      </div>
    </div>

    <div class="card" style="margin-bottom:20px">
      <div class="card-title" style="margin-bottom:14px">Procurement Cost Impact by Scenario</div>
      <table class="impact-table" style="width:100%">
        <thead>
          <tr>
            <th>Category</th>
            <th>Pre-Crisis Baseline</th>
            <th>1Q Closure</th>
            <th>2Q Closure</th>
            <th>3Q Closure</th>
            <th>Procurement Action</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Crude Oil</td>
            <td class="mono">~$70/bbl</td>
            <td class="mono amber-text">$97–110/bbl</td>
            <td class="mono warn-text">$110–115/bbl</td>
            <td class="mono up-text">$132+/bbl</td>
            <td>Lock in forward contracts now</td>
          </tr>
          <tr>
            <td>Ocean Freight (Asia–Europe)</td>
            <td class="mono">Baseline</td>
            <td class="mono amber-text">+15–20%</td>
            <td class="mono warn-text">+25–40%</td>
            <td class="mono up-text">+50%+</td>
            <td>Book Cape route capacity early</td>
          </tr>
          <tr>
            <td>Petrochemical Feedstocks</td>
            <td class="mono">Baseline</td>
            <td class="mono amber-text">+20–30%</td>
            <td class="mono warn-text">+35–50%</td>
            <td class="mono up-text">+60%+</td>
            <td>Source US shale-based alternatives</td>
          </tr>
          <tr>
            <td>Plastics & Polymers</td>
            <td class="mono">Baseline</td>
            <td class="mono amber-text">+15–25%</td>
            <td class="mono warn-text">+25–35%</td>
            <td class="mono up-text">+40%+</td>
            <td>Safety stock, dual sourcing</td>
          </tr>
          <tr>
            <td>Fertilizers (Urea)</td>
            <td class="mono">$475/MT</td>
            <td class="mono amber-text">$680/MT (+43%)</td>
            <td class="mono warn-text">$800–900/MT</td>
            <td class="mono up-text">$1,000+/MT</td>
            <td>Impact: food inflation cascade</td>
          </tr>
          <tr>
            <td>US Diesel</td>
            <td class="mono">~$3.65/gal</td>
            <td class="mono warn-text">~$5/gal (+37%)</td>
            <td class="mono warn-text">$5.50–6/gal</td>
            <td class="mono up-text">$6–7/gal</td>
            <td>Fleet fuel hedge, reduce road miles</td>
          </tr>
          <tr>
            <td>War-Risk Insurance</td>
            <td class="mono">0.125%</td>
            <td class="mono warn-text">0.2–0.4%</td>
            <td class="mono up-text">0.5–1.0%</td>
            <td class="mono up-text">1.0%+</td>
            <td>Factor into landed cost models</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="data-sources">
      <strong>Sources:</strong> Dallas Fed Economics (20 Mar 2026) — modelled 3 scenarios. Goldman Sachs: US inflation +0.8pp to 2.9%, GDP -0.3pp to 2.2%, recession probability 25%.
      Oxford Economics: $140/bbl for 2 months → eurozone + UK + Japan contraction. Bloomberg (20 Mar 2026).
    </div>
  </div>

  <!-- TAB 3: RISK MATRIX -->
  <div class="tab-panel" id="tab-risk">
    <div class="section-title">Procurement Category Risk Assessment — As of 23 Mar 2026</div>
    <p class="section-subtitle">Risk level based on price volatility, supply chain exposure, and alternative sourcing availability.</p>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:24px">
      <div class="risk-card critical">
        <div class="risk-header">
          <span class="risk-name">Energy & Fuels</span>
          <span class="risk-badge rb-critical">CRITICAL</span>
        </div>
        <div class="risk-impact up">Crude Oil +47% | Diesel +24%</div>
        <ul class="risk-items">
          <li>WTI surpassed $97/bbl; Brent peaked $126/bbl</li>
          <li>US diesel near $5/gal (+37% in one month)</li>
          <li>LPG up +28.1%, fuel oil +20.2%</li>
          <li>Every industry's logistics cost affected</li>
        </ul>
        <div class="progress-wrap">
          <div class="progress-label"><span>Exposure</span><span style="color:var(--red)">95%</span></div>
          <div class="progress-bar"><div class="progress-fill" style="width:95%;background:var(--red)"></div></div>
        </div>
      </div>

      <div class="risk-card critical">
        <div class="risk-header">
          <span class="risk-name">Petrochemical Feedstocks</span>
          <span class="risk-badge rb-critical">CRITICAL</span>
        </div>
        <div class="risk-impact up">Benzene +46% | Butadiene +49%</div>
        <ul class="risk-items">
          <li>Acrylic acid surged +85.1% — highest in dataset</li>
          <li>80% of Asia's naphtha from Middle East</li>
          <li>Force majeure: PCS (SG), Chandra Asri (ID), Yeochun NCC (KR)</li>
          <li>Styrene +37%, Benzene +46%, Acetone +37%</li>
        </ul>
        <div class="progress-wrap">
          <div class="progress-label"><span>Exposure</span><span style="color:var(--red)">92%</span></div>
          <div class="progress-bar"><div class="progress-fill" style="width:92%;background:var(--red)"></div></div>
        </div>
      </div>

      <div class="risk-card critical">
        <div class="risk-header">
          <span class="risk-name">Shipping & Logistics</span>
          <span class="risk-badge rb-critical">CRITICAL</span>
        </div>
        <div class="risk-impact up">+14–21 days | Cost +15–25%</div>
        <ul class="risk-items">
          <li>Maersk & Hapag-Lloyd suspended Mideast routes</li>
          <li>Cape of Good Hope rerouting mandatory</li>
          <li>Port congestion hits 2–5 weeks after reroute</li>
          <li>War-risk insurance: 0.125% → 0.2–0.4%</li>
        </ul>
        <div class="progress-wrap">
          <div class="progress-label"><span>Exposure</span><span style="color:var(--red)">90%</span></div>
          <div class="progress-bar"><div class="progress-fill" style="width:90%;background:var(--red)"></div></div>
        </div>
      </div>

