      plugins:{...defaults.plugins,tooltip:{callbacks:{label:v=>v.parsed.x+'% of imports'}}},
      scales:{
        x:{...defaults.scales.x,min:0,max:100,ticks:{...defaults.scales.x.ticks,callback:v=>v+'%'}},
        y:{...defaults.scales.y}
      }
    }
  });

  // Lead time
  new Chart(document.getElementById('leadTimeChart'),{
    type:'bar',
    data:{
      labels:['Electronics/IT','Auto Parts','Chemicals','Textiles','Food/Agri','Industrial Equip.','Consumer Goods'],
      datasets:[
        {label:'Normal Lead Time (days)',data:[22,25,18,20,14,28,16],backgroundColor:'rgba(44,181,192,0.4)',borderRadius:4,borderSkipped:false},
        {label:'Cape Reroute Add. Days',data:[16,18,14,16,12,18,14],backgroundColor:C.orange,borderRadius:4,borderSkipped:false}
      ]
    },
    options:{
      ...defaults,
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{display:true,labels:{color:C.text,font:{size:11,family:"'IBM Plex Mono',monospace"},boxWidth:12,padding:16}}
      },
      scales:{
        x:{...defaults.scales.x,stacked:true},
        y:{...defaults.scales.y,stacked:true,ticks:{...defaults.scales.y.ticks,callback:v=>v+'d'}}
      }
    }
  });
}
</script>
</body>
